# beamhop default sandbox — zsh login config

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git sudo command-not-found)
source "$ZSH/oh-my-zsh.sh"

# PATH: prefer /usr/local/bin (bun, npm-globals) ahead of system bins.
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# Friendly aliases.
alias ll='ls -lah'
alias claude-code='claude'

# History
HISTFILE=$HOME/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY HIST_IGNORE_DUPS

# Greet on interactive login.
if [[ -o interactive && -r "$HOME/.motd" ]]; then
  cat "$HOME/.motd"
fi
