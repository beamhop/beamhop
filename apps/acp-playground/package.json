{
  "name": "@beamhop/acp-playground",
  "version": "0.0.0",
  "private": true,
  "description": "Showcase app for @beamhop/acp-* SDK. Bun.serve full-stack: spawns ACP CLIs server-side, drives them from a React + Tailwind UI.",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "bun src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf node_modules/.cache *.tsbuildinfo test-results playwright-report"
  },
  "dependencies": {
    "@beamhop/acp-client": "workspace:*",
    "@beamhop/acp-protocol": "workspace:*",
    "@beamhop/acp-server": "workspace:*",
    "@beamhop/acp-ui": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/cli": "^4.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.0.0"
  }
}
