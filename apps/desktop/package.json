{
  "name": "@beamhop/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Beamhop desktop host — Tauri shell around the sidecar that runs sandboxes, terminals, and agents.",
  "type": "module",
  "scripts": {
    "dev": "bun run dev:sidecar & bun run dev:ui",
    "dev:ui": "bun --hot src/server.ts",
    "dev:sidecar": "bun --hot sidecar/index.ts",
    "dev:tauri": "BEAMHOP_SIDECAR_PORT=5176 bun --hot sidecar/index.ts & bun --hot src/server.ts",
    "build:sidecar": "bun build sidecar/index.ts --outfile dist/sidecar.js --target node --format esm --sourcemap --external microsandbox --external node-pty --external ws --external '@trystero-p2p/*' --external werift",
    "build:ui": "bun run build.ts",
    "build": "bun run build:sidecar && bun run build:ui",
    "test": "bun run test:e2e",
    "test:e2e": "playwright test",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist src-tauri/target node_modules/.cache *.tsbuildinfo"
  },
  "dependencies": {
    "@beamhop/acp-client": "workspace:*",
    "@beamhop/acp-p2p": "workspace:*",
    "@beamhop/acp-protocol": "workspace:*",
    "@beamhop/acp-server": "workspace:*",
    "@beamhop/beambox": "workspace:*",
    "@beamhop/host-orchestrator": "workspace:*",
    "@beamhop/invite-link": "workspace:*",
    "@beamhop/sandbox-exec": "workspace:*",
    "@beamhop/shell-client": "workspace:*",
    "@beamhop/shell-protocol": "workspace:*",
    "@beamhop/shell-server": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "@trystero-p2p/core": "^0.24.0",
    "@trystero-p2p/nostr": "^0.24.0",
    "@trystero-p2p/ws-relay": "^0.24.0",
    "@wterm/dom": "^0.3.0",
    "@wterm/react": "^0.3.0",
    "microsandbox": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "werift": "^0.22.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/cli": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.12",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.0.0"
  }
}
