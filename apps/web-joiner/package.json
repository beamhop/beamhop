{
  "name": "@beamhop/web-joiner",
  "version": "0.0.0",
  "private": true,
  "description": "Static SPA that joins a beamhop session over WebRTC from an invite link.",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "bun run build.ts",
    "preview": "bun src/server.ts --preview",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "clean": "rm -rf dist node_modules/.cache *.tsbuildinfo"
  },
  "dependencies": {
    "@beamhop/acp-client": "workspace:*",
    "@beamhop/acp-p2p": "workspace:*",
    "@beamhop/acp-protocol": "workspace:*",
    "@beamhop/invite-link": "workspace:*",
    "@beamhop/shell-client": "workspace:*",
    "@beamhop/shell-protocol": "workspace:*",
    "@trystero-p2p/core": "^0.24.0",
    "@trystero-p2p/nostr": "^0.24.0",
    "@trystero-p2p/ws-relay": "^0.24.0",
    "@wterm/dom": "^0.3.0",
    "@wterm/react": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@beamhop/acp-server": "workspace:*",
    "@beamhop/beambox": "workspace:*",
    "@beamhop/host-orchestrator": "workspace:*",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/cli": "^4.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-plugin-tailwind": "^0.1.2",
    "microsandbox": "*",
    "tailwindcss": "^4.0.0",
    "werift": "^0.22.5"
  }
}
