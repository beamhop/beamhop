{
  "name": "use-pi-mono",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:relay": "bun run --filter @beamhop/relay dev",
    "dev:host": "bun run --filter @beamhop/agent-host dev",
    "dev:client": "bun run --filter @beamhop/client dev",
    "build": "bun run --filter @beamhop/client build",
    "test": "bun test",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
