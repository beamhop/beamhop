{
  "name": "use-pi-mono",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --hot apps/host/src/server.ts",
    "build:host": "bun --filter @beamhop/host build",
    "prepare:tauri": "bash scripts/prepare-tauri.sh",
    "build:tauri": "bun run prepare:tauri && bunx tauri build --config apps/tauri/tauri.conf.json --target aarch64-apple-darwin",
    "test": "bun test"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  }
}
